<script>
function showWeek(n) {
  document.querySelectorAll('.week-panel').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.wtab').forEach(t => t.classList.remove('on'));
  document.getElementById('w'+n).classList.add('on');
  document.querySelectorAll('.wtab')[n-1].classList.add('on');
}

// Nav active state on scroll
const navLinks = document.querySelectorAll('.nav-link');
const sections = document.querySelectorAll('section[id], div[id]');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(s => {
    if (window.scrollY >= s.offsetTop - 80) current = s.id;
  });
  navLinks.forEach(l => {
    l.classList.toggle('active', l.getAttribute('href') === '#' + current);
  });
});

// Subtle fade-in on scroll
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.08 });

document.querySelectorAll('.subject-block, .essay-card, .tip-card, .cheat-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(16px)';
  el.style.transition = 'opacity .5s ease, transform .5s ease';
  observer.observe(el);
});
</script>
</body>
</html>
